import "package://github.com/jdx/hk/releases/download/v1.52.0/hk@1.52.0#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v1.52.0/hk@1.52.0#/Builtins.pkl"

// Keep in lockstep with the amends/import version above — bump both together.
min_hk_version = "1.52.0"

/// The lowest-common-denominator step set shared by every hugoh repo's
/// `hk.pkl`: the same key/value pairs, active and unmodified, across all of
/// them. Repo-specific overrides (excludes, custom commands, etc.) are
/// applied locally after spreading this in, e.g.:
///
/// ```
/// import "package://github.com/hugoh/hk-config/releases/download/v1.1.0/hk-config@1.1.0#/base.pkl" as Base
///
/// local linters = new Mapping<String, Step> {
///     ...Base.base
///     ["trailing_whitespace"] = (Builtins.trailing_whitespace) {
///         exclude = List("some/generated/dir/**")
///     }
/// }
/// ```
base: Mapping<String, Config.Step> = new Mapping<String, Config.Step> {
    ["actionlint"] = Builtins.actionlint
    ["pinact"] = Builtins.pinact
    ["check_merge_conflict"] = Builtins.check_merge_conflict
    ["trailing_whitespace"] = Builtins.trailing_whitespace
    ["mixed_line_ending"] = Builtins.mixed_line_ending
    ["newlines"] = Builtins.newlines
    ["check_case_conflict"] = Builtins.check_case_conflict
    ["check_added_large_files"] = Builtins.check_added_large_files
    ["check_executables_have_shebangs"] = Builtins.check_executables_have_shebangs
    ["check_symlinks"] = Builtins.check_symlinks
    ["gitleaks"] = Builtins.gitleaks
    ["ghalint_workflow"] = Builtins.ghalint_workflow
    ["rumdl"] = Builtins.rumdl
    ["rumdl_format"] = Builtins.rumdl_format
    ["biome"] = Builtins.biome
    ["zizmor"] = Builtins.zizmor
    ["typos"] = Builtins.typos
    ["mise"] = Builtins.mise
    ["tombi"] = Builtins.tombi
    ["tombi_format"] = Builtins.tombi_format
    ["ryl"] = Builtins.ryl
}

/// Python repos: ruff (lint + format) and ty (type checking). Spread this in
/// alongside `base`, then override individual keys locally for repo-specific
/// commands (e.g. running via `uv run` instead of a PATH binary).
python: Mapping<String, Config.Step> = new Mapping<String, Config.Step> {
    ["ruff"] = Builtins.ruff
    ["ruff_format"] = Builtins.ruff_format
    ["ty"] = Builtins.ty
}

/// Shell script repos: shellcheck, shellharden, shfmt. Deliberately doesn't
/// include ansible-lint (only relevant to the subset of shell repos running
/// Ansible) or secrets scanning (already in `base` via gitleaks).
shell: Mapping<String, Config.Step> = new Mapping<String, Config.Step> {
    ["shellcheck"] = Builtins.shellcheck
    ["shellharden"] = Builtins.shellharden
    ["shfmt"] = Builtins.shfmt
}

/// Deprecated: biome moved into `base` (it now also covers JSON, replacing
/// dprint). Kept as an empty group so repos still spreading `...Base.web`
/// don't break; drop that spread next time you touch those repos' `hk.pkl`.
web: Mapping<String, Config.Step> = new Mapping<String, Config.Step> {}

/// Lua repos (Hammerspoon Spoons, dotfiles): luacheck + stylua.
lua: Mapping<String, Config.Step> = new Mapping<String, Config.Step> {
    ["luacheck"] = Builtins.luacheck
    ["stylua"] = Builtins.stylua
}

/// Conventional Commit message linting. Needs `commit_msg_file`, which only
/// exists in a `commit-msg` hook — spread this into that hook's own steps,
/// never into `linters` (used by check/pre-commit/pre-push/fix), or the step
/// fails with "Variable `commit_msg_file` is not defined".
commit_msg: Mapping<String, Config.Step> = new Mapping<String, Config.Step> {
    ["check_conventional_commit"] = Builtins.check_conventional_commit
}
